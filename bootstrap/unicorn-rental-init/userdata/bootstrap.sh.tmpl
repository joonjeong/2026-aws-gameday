#!/bin/bash
set -euo pipefail

exec > >(tee /var/log/{{SERVICE_NAME}}-bootstrap.log) 2>&1
trap 'status=$?; echo "bootstrap failed for {{SERVICE_NAME}} with exit ${status}"; journalctl -u {{SERVICE_NAME}}.service --no-pager -n 100 || true; exit ${status}' ERR

dnf install -y awscli java-21-amazon-corretto-devel

install -d -o ec2-user -g ec2-user {{APP_DIRECTORY}}

for required_file in \
  "{{APP_SOURCE_PATH}}" \
  "{{ENV_FILE_PATH}}" \
  "{{SERVICE_UNIT_PATH}}"
do
  test -s "${required_file}"
done

command -v aws
aws --version
chmod 600 {{ENV_FILE_PATH}}
chmod 644 {{SERVICE_UNIT_PATH}}
chown ec2-user:ec2-user {{APP_SOURCE_PATH}}

javac --add-modules jdk.httpserver -d {{APP_DIRECTORY}} {{APP_SOURCE_PATH}}
chown -R ec2-user:ec2-user {{APP_DIRECTORY}}

systemctl daemon-reload
systemctl enable --now {{SERVICE_NAME}}.service

for attempt in $(seq 1 15); do
  if systemctl is-active --quiet {{SERVICE_NAME}}.service; then
    echo "{{SERVICE_NAME}}.service is active"
    exit 0
  fi
  sleep 1
done

echo "{{SERVICE_NAME}}.service did not become active"
journalctl -u {{SERVICE_NAME}}.service --no-pager -n 100 || true
exit 1
